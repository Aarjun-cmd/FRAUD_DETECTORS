# ── Groq AI (required for fraud analysis agents) ──────
# Get your FREE key from: https://console.groq.com
# Go to API Keys → Create API Key → copy the key starting with gsk_

VITE_GROQ_API_KEY=your_groq_api_key_here


# ── Supabase (required for chat session persistence) ───
# 1. Go to https://supabase.com → New Project
# 2. Once created: Settings → API → copy Project URL + anon/public key

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
